# Kevin Brian Ibarra Pineda
# HabitTracker — .gitignore

# ============================================
# 🐍 Python / Flask
# ============================================

# Archivos compilados de Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pkl
*.pdb
.Python

# Entornos virtuales
venv/
venvFB/
env/
ENV/
.venv/

# Distribución / empaquetado
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# ============================================
# 🔒 Archivos sensibles
# ============================================

# Variables de entorno (contienen credenciales)
.env
.env.production
.env.local
.env.*

# Credenciales de Firebase
firebase-credentials.json

# ============================================
# 📦 Base de datos y caché
# ============================================

*.sqlite3
*.log
*.bak
*.tmp
*.swp
instance/
.cache/

# ============================================
# 💻 Editores y sistema operativo
# ============================================

# Visual Studio Code
.vscode/
.history/
*.code-workspace

# MacOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# ============================================
# 🌐 HabitTracker — específico del proyecto
# ============================================

# Exportaciones generadas
static/exports/

# Archivos comprimidos
*.zip
*.tar.gz

# Documentación temporal
docs/*.tmp
docs/*.bak

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log
